<Window x:Class="YJI.Berka.Dashboard.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="설정"
        Height="620" Width="700"
        MinHeight="500" MinWidth="600"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F5F5F5">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="64"/>
        </Grid.RowDefinitions>

        <!-- 헤더 -->
        <Border Grid.Row="0" Background="White"
                BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
            <Grid Margin="24,0">
                <TextBlock Text="설정"
                           FontSize="16" FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
                <Button Content="X 닫기"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Height="32" Padding="16,0"
                        Background="White"
                        BorderBrush="#DDD" BorderThickness="1"
                        FontSize="12"
                        Click="OnClose"/>
            </Grid>
        </Border>

        <!-- 콘텐츠 -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24,20,24,0">

                <!-- DB 연결 정보 -->
                <Border Background="White"
                        BorderBrush="#E0E0E0" BorderThickness="1"
                        Padding="20" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="DB 연결 정보"
                                   FontSize="14" FontWeight="SemiBold"
                                   Margin="0,0,0,16"/>

                        <!-- Host -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Host" FontSize="13" Foreground="#555"
                                       VerticalAlignment="Center"/>
                            <Border Grid.Column="1" BorderBrush="#DDD" BorderThickness="1"
                                    Background="#F9F9F9" Padding="12,8">
                                <TextBlock x:Name="TxtHost" FontSize="12" Foreground="#333"/>
                            </Border>
                        </Grid>

                        <!-- Port -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Port" FontSize="13" Foreground="#555"
                                       VerticalAlignment="Center"/>
                            <Border Grid.Column="1" BorderBrush="#DDD" BorderThickness="1"
                                    Background="#F9F9F9" Padding="12,8">
                                <TextBlock x:Name="TxtPort" FontSize="12" Foreground="#333"/>
                            </Border>
                        </Grid>

                        <!-- Database -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Database" FontSize="13" Foreground="#555"
                                       VerticalAlignment="Center"/>
                            <Border Grid.Column="1" BorderBrush="#DDD" BorderThickness="1"
                                    Background="#F9F9F9" Padding="12,8">
                                <TextBlock x:Name="TxtDatabase" FontSize="12" Foreground="#333"/>
                            </Border>
                        </Grid>

                        <!-- Username -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Username" FontSize="13" Foreground="#555"
                                       VerticalAlignment="Center"/>
                            <Border Grid.Column="1" BorderBrush="#DDD" BorderThickness="1"
                                    Background="#F9F9F9" Padding="12,8">
                                <TextBlock x:Name="TxtUsername" FontSize="12" Foreground="#333"/>
                            </Border>
                        </Grid>

                        <!-- 연결 끊기 버튼 -->
                        <Button x:Name="BtnDisconnect"
                                Content="연결 끊기"
                                Height="36" Padding="16,0"
                                HorizontalAlignment="Left"
                                Background="White"
                                BorderBrush="#DDD" BorderThickness="1"
                                FontSize="13"
                                Click="OnDisconnect"/>
                    </StackPanel>
                </Border>

                <!-- 이상 탐지 임계값 -->
                <Border Background="White"
                        BorderBrush="#E0E0E0" BorderThickness="1"
                        Padding="20">
                    <StackPanel>
                        <TextBlock Text="이상 탐지 설정"
                                   FontSize="14" FontWeight="SemiBold"
                                   Margin="0,0,0,16"/>

                        <!-- Z-Score -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Z-Score 임계값" FontSize="13" Foreground="#555"
                                       VerticalAlignment="Center"/>
                            <Border Grid.Column="1" BorderBrush="#DDD" BorderThickness="1"
                                    Background="#F9F9F9" Padding="12,8">
                                <TextBlock Text="2.5" FontSize="12" Foreground="#333"/>
                            </Border>
                        </Grid>

                        <!-- IForest -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Isolation Forest 오염도" FontSize="13" Foreground="#555"
                                       VerticalAlignment="Center"/>
                            <Border Grid.Column="1" BorderBrush="#DDD" BorderThickness="1"
                                    Background="#F9F9F9" Padding="12,8">
                                <TextBlock Text="0.05 (5%)" FontSize="12" Foreground="#333"/>
                            </Border>
                        </Grid>

                        <!-- AE -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Autoencoder 오차 임계" FontSize="13" Foreground="#555"
                                       VerticalAlignment="Center"/>
                            <Border Grid.Column="1" BorderBrush="#DDD" BorderThickness="1"
                                    Background="#F9F9F9" Padding="12,8">
                                <TextBlock Text="자동 산출 (상위 5%)" FontSize="12" Foreground="#333"/>
                            </Border>
                        </Grid>

                        <!-- 안내 메시지 -->
                        <Border Background="#F9F9F9" BorderBrush="#EEE" BorderThickness="1"
                                Padding="12,10">
                            <TextBlock FontSize="11" Foreground="#888" TextWrapping="Wrap"
                                       Text="※ 임계값 변경은 BerkaETLPipeline에서 config.py 수정 후 detection_pipeline 재실행이 필요합니다."/>
                        </Border>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- 하단 버튼 -->
        <Border Grid.Row="2" Background="White"
                BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Margin="24,0">
                <Button Content="닫기"
                        Height="36" Padding="24,0"
                        Background="White"
                        BorderBrush="#DDD" BorderThickness="1"
                        FontSize="13"
                        Click="OnClose"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>