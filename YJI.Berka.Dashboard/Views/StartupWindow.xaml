<Window x:Class="YJI.Berka.Dashboard.Views.StartupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BerkaAnalytics"
        Height="680" Width="900"
        MinHeight="500" MinWidth="700"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="#F5F5F5">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="32"/>
        </Grid.RowDefinitions>

        <!-- 메인 콘텐츠 -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 타이틀 -->
            <StackPanel Grid.Column="1" Grid.Row="1" Margin="0,0,0,0">
                <TextBlock Text="BerkaAnalytics"
                           FontSize="28" FontWeight="Bold"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Financial Data Analysis Dashboard"
                           FontSize="13" Foreground="#888"
                           HorizontalAlignment="Center"
                           Margin="0,6,0,0"/>
            </StackPanel>

            <!-- 구분선 -->
            <Separator Grid.Column="1" Grid.Row="2" Margin="0,24,0,24" Background="#DDD"/>

            <!-- DB 연결 설정 타이틀 -->
            <TextBlock Grid.Column="1" Grid.Row="3"
                       Text="DB 연결 설정"
                       FontSize="15" FontWeight="SemiBold"
                       Margin="0,0,0,20"/>

            <!-- 입력 필드들 -->
            <StackPanel Grid.Column="1" Grid.Row="4" Margin="0,0,0,16">
                <TextBlock Text="Host" FontSize="13" Foreground="#555" Margin="0,0,0,6"/>
                <TextBox x:Name="TxtHost" Text="localhost"
                         Height="40" Padding="12,0"
                         VerticalContentAlignment="Center"
                         BorderBrush="#DDD" BorderThickness="1"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Grid.Row="5" Margin="0,0,0,16">
                <TextBlock Text="Port" FontSize="13" Foreground="#555" Margin="0,0,0,6"/>
                <TextBox x:Name="TxtPort" Text="3306"
                         Height="40" Padding="12,0"
                         VerticalContentAlignment="Center"
                         BorderBrush="#DDD" BorderThickness="1"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Grid.Row="6" Margin="0,0,0,16">
                <TextBlock Text="Database" FontSize="13" Foreground="#555" Margin="0,0,0,6"/>
                <TextBox x:Name="TxtDatabase" Text="berka"
                         Height="40" Padding="12,0"
                         VerticalContentAlignment="Center"
                         BorderBrush="#DDD" BorderThickness="1"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Grid.Row="7" Margin="0,0,0,16">
                <TextBlock Text="Username" FontSize="13" Foreground="#555" Margin="0,0,0,6"/>
                <TextBox x:Name="TxtUsername" Text="berka_user"
                         Height="40" Padding="12,0"
                         VerticalContentAlignment="Center"
                         BorderBrush="#DDD" BorderThickness="1"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Grid.Row="8" Margin="0,0,0,24">
                <TextBlock Text="Password" FontSize="13" Foreground="#555" Margin="0,0,0,6"/>
                <PasswordBox x:Name="PwdPassword"
                             Height="40" Padding="12,0"
                             VerticalContentAlignment="Center"
                             BorderBrush="#DDD" BorderThickness="1"/>
            </StackPanel>

            <!-- 버튼 -->
            <Grid Grid.Column="1" Grid.Row="9" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Content="연결 테스트"
                        Height="44"
                        Background="White"
                        BorderBrush="#DDD" BorderThickness="1"
                        FontSize="14"
                        Click="OnTestConnection"/>

                <Button Grid.Column="2"
                        x:Name="BtnStart"
                        Content="시작하기"
                        Height="44"
                        Background="#111" Foreground="White"
                        BorderThickness="0"
                        FontSize="14"
                        IsEnabled="False"
                        Click="OnStart"/>
            </Grid>

            <!-- 상태 메시지 -->
            <Border Grid.Column="1" Grid.Row="10"
                    Background="White" BorderBrush="#EEE" BorderThickness="1"
                    CornerRadius="4" Padding="12,10">
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="10" Height="10" Fill="#CCC" Margin="0,0,8,0"
                             VerticalAlignment="Center"/>
                    <TextBlock x:Name="TxtStatus"
                               Text="연결 대기 중 — 연결 테스트를 먼저 실행하세요"
                               FontSize="12" Foreground="#888"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- 하단 상태바 -->
        <Border Grid.Row="1" Background="White" BorderBrush="#DDD" BorderThickness="0,1,0,0">
            <Grid Margin="24,0">
                <TextBlock x:Name="TxtStatusBar"
                           Text="DB: 연결 대기"
                           FontSize="11" Foreground="#888"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Left"/>
                <TextBlock Text="BerkaAnalytics v1.0.0"
                           FontSize="11" Foreground="#888"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"/>
            </Grid>
        </Border>
    </Grid>
</Window>
